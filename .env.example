# Copy to .env.local for development. In deployed environments set these in the
# Vercel project settings. lib/env.ts validates the required ones at module
# load, so a missing value fails loudly and by name instead of surfacing as
# "supabaseUrl is required" on every request.

# --- Required -------------------------------------------------------------

# Supabase project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable ("anon") key. Safe to expose to the browser — RLS is the
# security boundary. Never put the service-role key in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Optional -------------------------------------------------------------

# Absolute origin used for canonical URLs, Open Graph tags, robots.txt and the
# sitemap. Falls back to https://nookph.app. Set this explicitly in production:
# if it is wrong, every canonical and every sitemap entry points at the wrong
# host, which is an SEO failure that is easy to miss.
NEXT_PUBLIC_SITE_URL=
